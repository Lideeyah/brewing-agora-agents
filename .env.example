# ── Circle Developer-Controlled Wallets ──────────────────────────────────────
# 1. Go to https://console.circle.com → Settings → API Keys → Create Key
CIRCLE_API_KEY=

# 2. Generate locally: openssl rand -hex 32
#    Then register at: console.circle.com → Developer-Controlled Wallets → Entity Secret
CIRCLE_ENTITY_SECRET=

# 3. Created in Circle Console → Developer-Controlled Wallets → Wallet Sets → Create
CIRCLE_WALLET_SET_ID=

# ── Arc Testnet ───────────────────────────────────────────────────────────────
# Arc testnet RPC (confirm latest at https://arc.network)
ARC_RPC_URL=https://rpc-arc-testnet.circle.com

# Funded Arc testnet private key for signing (interim until Circle DCW is live)
# Fund at: https://faucet.circle.com → select Arc Testnet → paste your address
ARC_PRIVATE_KEY=

# ── Contracts (fill in AFTER running deploy.py) ───────────────────────────────
ESCROW_CONTRACT_ADDRESS=
USDC_ADDRESS=

# ── AI Workers ───────────────────────────────────────────────────────────────
# From https://console.anthropic.com
ANTHROPIC_API_KEY=
